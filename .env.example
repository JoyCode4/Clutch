# Copy this file to ".env" and fill in your key. ".env" is git-ignored.

# ---- LLM provider — works with any of: gemini | openai | groq | huggingface | custom ----
VITE_LLM_PROVIDER=gemini
# API key for the chosen provider
VITE_LLM_API_KEY=
# optional model override (a sensible default is used per provider if blank)
#   gemini      -> gemini-2.5-flash
#   openai      -> gpt-4o-mini
#   groq        -> llama-3.3-70b-versatile  (use 70b, NOT 8b — 8b hallucinates tool calls)
#   huggingface -> meta-llama/Llama-3.3-70B-Instruct
VITE_LLM_MODEL=
# only for provider=custom (any OpenAI-compatible base URL)
VITE_LLM_BASE_URL=

# Legacy Gemini key (used when provider=gemini and VITE_LLM_API_KEY is empty)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# Day 2 (Google Calendar) — OAuth Web client ID
VITE_GOOGLE_OAUTH_CLIENT_ID=566436571473-g47a8gdnhcoa1hdl12g6cc49k1fbur8n.apps.googleusercontent.com
